%GLOBAL mosto_param_class;          *<-; %LET mosto_param_class         = &treat_var.;
%GLOBAL mosto_param_class_order;    *<-; %LET mosto_param_class_order   = 100 101;  * <Quote from Data Display Guide: Order of doses: Highest (first) to lowest of BSP treatments then placebo and/or control drug.>;
%GLOBAL mosto_param_order_var;      *<-; %LET mosto_param_order_var     = &treat_var. = &mosto_param_class_order.;

*setting for trtgrp;
